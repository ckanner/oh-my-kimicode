{
  "name": "@oh-my-kimicode/oh-my-kimicode",
  "version": "0.1.0",
  "description": "OmO agent harness for Kimi Code CLI",
  "type": "module",
  "bin": {
    "oh-my-kimicode": "./bin/oh-my-kimicode.mjs"
  },
  "files": [
    "dist/",
    "plugin/",
    "scripts/",
    "bin/"
  ],
  "scripts": {
