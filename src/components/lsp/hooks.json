[
  {
    "event": "PostToolUse",
    "matcher": "^(Write|Edit)$",
    "timeout": 60,
    "statusMessage": "(LazyKimiCode) Checking LSP Diagnostics"
  },
  {
    "event": "PostCompact",
    "matcher": ".*",
    "timeout": 10,
    "statusMessage": "(LazyKimiCode) Resetting LSP Diagnostics Cache"
  }
]
