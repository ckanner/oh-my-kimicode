[
  {
    "event": "PostToolUse",
    "matcher": "^(Write|Edit|apply_patch|multi_edit)$",
    "timeout": 60,
    "statusMessage": "(LazyKimiCode) Checking LSP Diagnostics"
  },
  {
    "event": "PreCompact",
    "matcher": ".*",
    "timeout": 5,
    "statusMessage": "(LazyKimiCode) Preparing LSP Diagnostics Cache"
  },
  {
    "event": "PostCompact",
    "matcher": ".*",
    "timeout": 10,
    "statusMessage": "(LazyKimiCode) Resetting LSP Diagnostics Cache"
  }
]
