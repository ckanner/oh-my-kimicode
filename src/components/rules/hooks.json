[
  {
    "event": "SessionStart",
    "matcher": ".*",
    "timeout": 30,
    "statusMessage": "(LazyKimiCode) Loading project rules"
  },
  {
    "event": "UserPromptSubmit",
    "matcher": ".*",
    "timeout": 30,
    "statusMessage": "(LazyKimiCode) Loading project rules"
  },
  {
    "event": "PostToolUse",
    "matcher": "^(Write|Edit|apply_patch|multi_edit)$",
    "timeout": 30,
    "statusMessage": "(LazyKimiCode) Matching project rules"
  },
  {
    "event": "PreCompact",
    "matcher": ".*",
    "timeout": 5,
    "statusMessage": "(LazyKimiCode) Preparing project rule cache"
  },
  {
    "event": "PostCompact",
    "matcher": ".*",
    "timeout": 10,
    "statusMessage": "(LazyKimiCode) Resetting project rule cache"
  }
]
